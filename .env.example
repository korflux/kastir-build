# Copy to `.env` before `docker compose up -d`:
#   cp .env.example .env
#
# Required: Docker Engine + Compose. This package pulls the prebuilt Kastir
# image — you do not need Node, pnpm, or the private source repository.

# Database and Redis connection strings the app itself uses. The defaults
# below already match the postgres/redis services bundled in this
# docker-compose.yml (hostnames `postgres`/`redis`, credentials from
# POSTGRES_*/REDIS_PASSWORD further down) — leave them as-is for a fresh
# install. Already running Postgres/Redis elsewhere (shared with another
# app in the same project, a managed instance)? Point these two at that
# instead, and remove the postgres/redis services from docker-compose.yml.
DATABASE_URL=postgresql://kastir:kastir@postgres:5432/kastir
REDIS_URL=redis://:kastir@redis:6379

# Public origin browsers use (cookies, CSRF, redirects). Must match the URL.
BETTER_AUTH_URL=http://localhost:8080

# Better Auth secret — at least 32 random characters.
NEXTAUTH_SECRET=replace-with-at-least-32-random-characters

# First-boot Master administrator (created once, idempotent).
MASTER_EMAIL=admin@example.com
MASTER_PASSWORD=replace-with-a-strong-password
# true only for controlled credential recovery; default false.
MASTER_FORCE_RESET=false

# Behind a reverse proxy that overwrites X-Forwarded-For / X-Real-IP.
# The in-container Nginx already does; keep true for typical Docker/VPS.
AUTH_TRUST_PROXY=true

# Optional panel defaults
SITE_TITLE=Kastir
PANEL_LANGUAGE=en

# Host port mapped to the container Nginx (:80)
HTTP_PORT=8080

# Only used to initialize the bundled postgres/redis containers above (not
# exposed on the host by default) — keep in sync with DATABASE_URL/REDIS_URL
# if you change these. Change defaults before any real deployment.
POSTGRES_USER=kastir
POSTGRES_PASSWORD=kastir
POSTGRES_DB=kastir
REDIS_PASSWORD=kastir

# Optional: pin or override the app image (default ghcr.io/korflux/kastir:latest)
# KASTIR_IMAGE=ghcr.io/korflux/kastir:latest

# Optional: max size in bytes for site backup import packages (default is set in the app).
# BACKUP_MAX_BYTES=536870912
